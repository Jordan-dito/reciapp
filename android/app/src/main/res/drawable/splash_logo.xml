<?xml version="1.0" encoding="utf-8"?>
<!-- Logo del splash: círculo blanco con icono de reciclaje verde (igual que login) -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Círculo blanco de fondo (100dp como en login) -->
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/white" />
            <size
                android:width="100dp"
                android:height="100dp" />
        </shape>
    </item>
    
    <!-- Icono de reciclaje verde usando el icono de launcher (que debería ser el logo de reciclaje) -->
    <item
        android:width="60dp"
        android:height="60dp"
        android:gravity="center">
        <bitmap
            android:gravity="center"
            android:src="@mipmap/ic_launcher" />
    </item>
</layer-list>
